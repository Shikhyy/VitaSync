POSTGRES_DB=vitasync
POSTGRES_USER=vitasync
POSTGRES_PASSWORD=replace-with-a-long-random-password

MINIO_ROOT_USER=vitasync
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password

SECRET_KEY=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://165.245.142.215,http://165.245.142.215:8080

FRONTEND_PORT=8080
API_PORT=8000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
VLLM_PORT=8001

VITE_API_URL=/api
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_DTYPE=float16
VLLM_MAX_MODEL_LEN=32768
CELERY_CONCURRENCY=4

# x402 payment rail for paid Qwen queries.
# Leave disabled until you have a receiving wallet and facilitator configured.
X402_ENABLED=false
X402_PAY_TO=0xYourReceivingWallet
X402_FACILITATOR_URL=
X402_NETWORK=eip155:8453
X402_ASSET=USDC
X402_ASSET_ADDRESS=
